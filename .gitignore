# ---- Root .gitignore for Java Spring Boot + React monorepo ----

# OS-specific
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# Editor/IDE
.vscode/
.idea/
/.idea/
/idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# Node/React
node_modules/
.npm/
.pnp*
.pnpm-store/
.eslintcache
.nyc_output/
coverage/
.cypress/
.playwright/

# React build artifacts
build/
dist/
.cache/
.parcel-cache/
.vite/
storybook-static/
.next/

# Java / Spring / Build tools
# Maven
target/
.mvn/timing.properties
# Keep Maven wrapper jar if present
!.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
# Keep Gradle wrapper jar if present
!gradle/wrapper/gradle-wrapper.jar

# Common Java artifacts
out/
bin/
*.class
*.war
*.ear
*.nar
*.zip
*.tar
*.tar.gz

# Spring Boot logs
spring.log

# Local application configs (examples/templates should be committed instead)
application-local.properties
application-local.yml
application-*.local.yml
application-*.local.properties

# Logs & diagnostics
logs/
log/
*.log
*.log.*
*.hprof
hs_err_pid*
replay_pid*

# Temporary files
*.tmp
*.temp
.tmp/
tmp/
*~
*.swp
*.swo

# TypeScript build info
*.tsbuildinfo

# Test output & reports
reports/
test-output/

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker local artifacts (optional; keep templates committed)
.docker/

# Agent ignores
.slingshot/
.agent/

# End of .gitignore
